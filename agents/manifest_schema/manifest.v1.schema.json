{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentfabric.dev/schemas/manifest.v1.schema.json",
  "title": "AgentFabric Manifest v1",
  "type": "object",
  "required": [
    "manifest_version",
    "name",
    "description",
    "entrypoint",
    "permissions"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
