{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentfabric.dev/schemas/manifest.v1.schema.json",
  "title": "AgentFabric Manifest v1",
  "type": "object",
  "required": [
    "manifest_version",
    "name",
    "description",
    "entrypoint",
    "permissions"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_version": {
      "type": "string",
      "const": "v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "allow_network": {
          "type": "boolean"
        },
        "allowed_filesystem_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "max_run_seconds": {
      "type": "number",
      "minimum": 0
    },
    "max_tool_calls": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
