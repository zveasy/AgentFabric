{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentfabric.dev/schemas/manifest.v1.schema.json",
  "title": "AgentFabric Agent Manifest v1",
  "description": "Compatibility schema for runtime and marketplace manifests.",
  "type": "object",
  "required": [
    "name",
    "description"
  ],
  "anyOf": [
    {
      "required": [
        "version"
      ]
    },
    {
      "required": [
        "manifest_version"
      ]
    }
  ],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Unique agent identifier (snake_case)."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$",
      "description": "Semantic version string for runtime package manifests."
    },
    "manifest_version": {
      "type": "string",
      "enum": [
        "v1",
        "1"
      ],
      "description": "Manifest schema version for control-plane payloads."
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "allow_network": {
          "type": "boolean"
        },
        "allowed_filesystem_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "max_run_seconds": {
      "type": "number",
      "minimum": 0
    },
    "max_tool_calls": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "type": "object"
    },
    "category": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "license": {
      "type": "string"
    }
  }
}
